# ── PartPilot SUBPATH deployment config (behind CloudPanel) ──────────────────
# Copy to the repo root as ".env":  cp deploy/.env.subpath.example .env

# Path prefix the app is served under. The public URL becomes
# https://<your-domain>${BASE_PATH}/login  (e.g. https://ikiousa.tech/partpilot/login).
# No trailing slash. Must be the same in CloudPanel's proxy location.
BASE_PATH=/partpilot

# Database (Docker-managed MySQL). Use a strong, URL-safe password
# (letters/digits, no @ : / # ?). This is the internal container DB, not the
# host MySQL — it lives in the db_data volume and is not exposed to the network.
MYSQL_ROOT_PASSWORD=change_me_strong_password
MYSQL_DATABASE=partpilot

# Session cookie signing secret — MUST be a long random string.
# Generate one:  openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_hex_string

# ── AI provider (optional) ───────────────────────────────────────────────────
# Insights/predictions work with NO key. For chat + narratives, add a free Groq
# key (https://console.groq.com/keys) or point AI_BASE_URL at a local model.
GROQ_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
# AI_BASE_URL=http://host.docker.internal:11434/v1   # local Ollama/LM Studio
# OPENAI_API_KEY=
