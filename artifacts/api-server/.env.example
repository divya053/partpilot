PORT=3001
DATABASE_URL=mysql://root:@127.0.0.1:3306/part_number_ai

# Secret used to sign session cookies (auth). Use a long random string in prod.
SESSION_SECRET=change-me-to-a-long-random-string-please

# ─── AI provider ───────────────────────────────────────────────────────────
# The portal's AI features (assistant chat, insights narratives, builder
# suggestions, explanations) run on ANY OpenAI-compatible chat API.
# Deterministic insights work even with NO key configured.
#
# Recommended: FREE Groq API — get a key at https://console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL is chosen via AI_MODEL (defaults to llama-3.3-70b-versatile).

# Optional: run a LOCAL model instead (Ollama / LM Studio / vLLM).
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_MODEL=llama3.1
#   AI_API_KEY=local-no-key-required

# Optional: classic OpenAI.
#   OPENAI_API_KEY=your_openai_api_key
#   OPENAI_MODEL=gpt-4o-mini

# Optional: override the model name for whichever provider is active.
# AI_MODEL=llama-3.3-70b-versatile
