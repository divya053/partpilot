# PartPilot API configuration — copy to .env and adjust as needed.
PORT=4100

# MySQL (XAMPP / phpMyAdmin defaults: root, no password)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=partpilot

# Session signing secret (change in production)
SESSION_SECRET=partpilot-dev-secret-change-me

# --- Optional AI (free / local). Leave blank to use deterministic insights only. ---
# Groq (free, OpenAI-compatible):  https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Or a fully local OpenAI-compatible endpoint (e.g. Ollama / LM Studio):
AI_BASE_URL=
AI_MODEL=
