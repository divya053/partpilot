# PartPilot API — PRODUCTION example (copy to server/.env on the VPS).
PORT=4100

# MySQL on the VPS. Point this at your MySQL and create an empty `partpilot` DB.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=partpilot
DB_PASSWORD=CHANGE_ME
DB_NAME=partpilot

# Long random string — used to sign session cookies.
SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# App is served under /partpilot, so scope the session cookie to it.
SESSION_COOKIE_PATH=/partpilot

# Optional free/local AI. Leave blank for deterministic insights only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
AI_BASE_URL=
AI_MODEL=
